# ============================================================
#  AI Email Assistant — Environment Variables
# ============================================================
#
#  Copy this file to .env for local development:
#    cp .env.example .env
#  then fill in your values.
#
#  For production (GitHub Actions), add these as repository
#  Secrets at:
#    Settings → Secrets and variables → Actions → New repository secret
#
#  NEVER commit a .env file with real values.
# ============================================================

# ---- Gmail (required) ----------------------------------------
# Obtain via: python scripts/setup_gmail_auth.py
GMAIL_CLIENT_ID=your-client-id.apps.googleusercontent.com
GMAIL_CLIENT_SECRET=your-client-secret
GMAIL_REFRESH_TOKEN=your-refresh-token

# ---- Anthropic / Claude (required) ---------------------------
# Create at: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-...

# ---- Notion (optional) ---------------------------------------
# Create an integration at: https://www.notion.so/my-integrations
# Then share the target database/pages with your integration.
NOTION_API_KEY=secret_...
# ID of a Notion database used as a knowledge base (optional)
NOTION_DATABASE_ID=
# Comma-separated list of Notion page IDs to include (optional)
NOTION_PAGE_IDS=

# ---- HubSpot (optional) --------------------------------------
# Create a Private App at:
#   HubSpot → Settings → Integrations → Private Apps
# Required scopes: crm.objects.contacts.read,
#                  crm.objects.companies.read,
#                  crm.objects.deals.read
HUBSPOT_ACCESS_TOKEN=pat-na1-...

# ---- Behaviour (optional) ------------------------------------
# Maximum number of emails processed per run (default: 10)
MAX_EMAILS=10

# Set to "true" to analyse emails without creating any drafts
DRY_RUN=false

# ---- Persona (required) --------------------------------------
# Personal details for the executive the assistant represents.
# These are used when config/persona.yaml fields are blank.
EXECUTIVE_NAME=
EXECUTIVE_ROLE=
EXECUTIVE_COMPANY=
EMAIL_TONE=professional and concise
EMAIL_SIGN_OFF=Best,
{name}
# Multi-line notes about the executive's style, preferences, and context.
# Use 
 to separate lines.
EXECUTIVE_NOTES=
# IANA timezone name, e.g. "America/New_York", "Europe/Paris"
SCHEDULING_TIMEZONE=
